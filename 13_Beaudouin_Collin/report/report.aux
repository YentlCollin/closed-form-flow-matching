\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Cosine similarity histograms between $\hat  {u}^\star $ and $u^{\mathrm  {cond}}$ for three 2D datasets ($n = 5000$) at various time steps. The progressive concentration near~1 confirms the collapse to a single conditional direction. In 2D the stochastic regime persists until intermediate~$t$, consistent with the paper's Figure~1a (top row, two-moons).\relax }}{9}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:cosine-hist}{{1}{9}{Cosine similarity histograms between $\hat {u}^\star $ and $u^{\mathrm {cond}}$ for three 2D datasets ($n = 5000$) at various time steps. The progressive concentration near~1 confirms the collapse to a single conditional direction. In 2D the stochastic regime persists until intermediate~$t$, consistent with the paper's Figure~1a (top row, two-moons).\relax }{figure.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces (a)~Percentage of pairs with $\qopname  \relax o{cos}(\hat  {u}^\star , u^{\mathrm  {cond}}) > 0.9$ vs.\ $t$, for varying data dimension~$d$ ($n = 2000$). Higher dimension leads to earlier collapse, consistent with the paper's Figure~1c on Imagenette. (b)~Empirical collapse time matches the $\propto \!\qopname  \relax o{log}(n)/d$ scaling from~\cite  {biroli2024dynamical} for both $n = 500$ and $n = 2000$.\relax }}{10}{figure.caption.2}\protected@file@percent }
\newlabel{fig:dim-dependence}{{2}{10}{(a)~Percentage of pairs with $\cos (\hat {u}^\star , u^{\mathrm {cond}}) > 0.9$ vs.\ $t$, for varying data dimension~$d$ ($n = 2000$). Higher dimension leads to earlier collapse, consistent with the paper's Figure~1c on Imagenette. (b)~Empirical collapse time matches the $\propto \!\log (n)/d$ scaling from~\cite {biroli2024dynamical} for both $n = 500$ and $n = 2000$.\relax }{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Collapse time $t_C$ vs.\ dataset size~$n$ at fixed $d = 50$ and $d = 100$. The empirical values follow the $\propto \!\qopname  \relax o{log}(n)/d$ scaling (dashed line), confirming the logarithmic dependence on~$n$.\relax }}{10}{figure.caption.3}\protected@file@percent }
\newlabel{fig:collapse-vs-n}{{3}{10}{Collapse time $t_C$ vs.\ dataset size~$n$ at fixed $d = 50$ and $d = 100$. The empirical values follow the $\propto \!\log (n)/d$ scaling (dashed line), confirming the logarithmic dependence on~$n$.\relax }{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Velocity approximation error $\mathbb  {E}\left \lVert u_\theta - \hat  {u}^\star  \right \rVert ^2$ vs.\ $t$ for varying dataset sizes on the $d = 100$ Gaussian mixture. Two failure zones are visible: an early-time bump at $t \approx 0.12$--$0.15$ (most prominent for $n = 10$), and a late-time rise for $n \geq 200$.\relax }}{10}{figure.caption.4}\protected@file@percent }
\newlabel{fig:velocity-error}{{4}{10}{Velocity approximation error $\E \norm {u_\theta - \hat {u}^\star }^2$ vs.\ $t$ for varying dataset sizes on the $d = 100$ Gaussian mixture. Two failure zones are visible: an early-time bump at $t \approx 0.12$--$0.15$ (most prominent for $n = 10$), and a late-time rise for $n \geq 200$.\relax }{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces (a)~The nearest-neighbor distance between generated and training samples increases with $n$, indicating a transition from memorization to generalization as the dataset outgrows the network's capacity. (b)~PCA projections confirm the trend: for small $n$, generated points (red) cluster near training data (blue); for large~$n$, the model produces diverse samples with the same modal structure.\relax }}{11}{figure.caption.5}\protected@file@percent }
\newlabel{fig:nn-dist-scatter}{{5}{11}{(a)~The nearest-neighbor distance between generated and training samples increases with $n$, indicating a transition from memorization to generalization as the dataset outgrows the network's capacity. (b)~PCA projections confirm the trend: for small $n$, generated points (red) cluster near training data (blue); for large~$n$, the model produces diverse samples with the same modal structure.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Mean nearest-neighbor distance as a function of the hybrid switching time $\tau $ (2D Gaussian mixture, $n=2000$). Plateau for $\tau \leq 0.2$, sharp drop above $\tau \approx 0.35$.\relax }}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:fig3-switching}{{6}{11}{Mean nearest-neighbor distance as a function of the hybrid switching time $\tau $ (2D Gaussian mixture, $n=2000$). Plateau for $\tau \leq 0.2$, sharp drop above $\tau \approx 0.35$.\relax }{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Switching curves for three 2D geometries ($n=2000$). The switching time varies with dataset structure, reflecting the complexity of $\hat  {u}^\star $.\relax }}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:fig3-geometry}{{7}{11}{Switching curves for three 2D geometries ($n=2000$). The switching time varies with dataset structure, reflecting the complexity of $\hat {u}^\star $.\relax }{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Switching time vs.\ dimension. Left: switching point shifts earlier as $d$ grows. Right: at very high $d$, the curve is flat --- even $\hat  {u}^\star $ generalizes, consistent with the $\mathcal  {O}(\qopname  \relax o{log}n / d)$ collapse time scaling.\relax }}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:fig3-dim}{{8}{12}{Switching time vs.\ dimension. Left: switching point shifts earlier as $d$ grows. Right: at very high $d$, the curve is flat --- even $\hat {u}^\star $ generalizes, consistent with the $\mathcal {O}(\log n / d)$ collapse time scaling.\relax }{figure.caption.8}{}}
\newlabel{fig:fig3-capacity}{{9a}{12}{Effect of model capacity (hidden dim).\relax }{figure.caption.9}{}}
\newlabel{sub@fig:fig3-capacity}{{a}{12}{Effect of model capacity (hidden dim).\relax }{figure.caption.9}{}}
\newlabel{fig:fig3-training}{{9b}{12}{Effect of training duration (\# steps).\relax }{figure.caption.9}{}}
